{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "acst/team-member",
    "version": "1.0.0",
    "title": "Team Member",
    "category": "ac-starter-toolkit",
    "icon": "admin-users",
    "description": "Display team member profiles with photo, name, role, bio, and social links.",
    "keywords": [ "team", "member", "staff", "profile", "person" ],
    "supports": {
        "html": false,
        "align": [ "wide", "full" ],
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        },
        "typography": {
            "fontSize": true
        }
    },
    "attributes": {
        "name": {
            "type": "string",
            "default": "John Doe"
        },
        "nameTag": {
            "type": "string",
            "default": "h3"
        },
        "role": {
            "type": "string",
            "default": "Designer"
        },
        "bio": {
            "type": "string",
            "default": "A short description about this team member."
        },
        "imageUrl": {
            "type": "string",
            "default": ""
        },
        "imageId": {
            "type": "number",
            "default": 0
        },
        "imageAlt": {
            "type": "string",
            "default": ""
        },
        "linkUrl": {
            "type": "string",
            "default": ""
        },
        "linkTarget": {
            "type": "string",
            "default": ""
        },
        "layout": {
            "type": "string",
            "default": "card"
        },
        "socialLinks": {
            "type": "array",
            "default": [
                { "network": "facebook", "url": "#" },
                { "network": "twitter", "url": "#" },
                { "network": "linkedin", "url": "#" }
            ]
        }
    },
    "textdomain": "ac-starter-toolkit",
    "render": "file:./render.php"
}
